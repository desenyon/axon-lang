# ============================================================
# Retrieval-Augmented Generation (RAG) Pipeline
# Demonstrates: rag blocks, document ingestion, chunking,
# sentence-transformer embedding, FAISS vector store,
# hybrid search, reranking, LLM generation, and evaluation.
# ============================================================

data DocumentCorpus:
    source: "datasets/enterprise_docs/"
    format: mixed                      # pdf, docx, txt, html
    recursive: true
    file_types: [".pdf", ".docx", ".txt", ".md", ".html"]
    encoding: utf-8
    exclude_patterns: ["**/tmp/**", "**/.git/**"]

# Document chunking strategy
feature DocumentChunker:
    source: DocumentCorpus
    strategy: recursive_character
    chunk_size: 512
    chunk_overlap: 64
    separators: ["\n\n", "\n", ". ", " "]
    add_metadata: true
    metadata_fields: [source_file, page_number, section_title, date_modified]
    min_chunk_length: 100

# Bi-encoder for dense retrieval
embedding SentenceEmbedder:
    model: "BAAI/bge-large-en-v1.5"
    device: cuda
    batch_size: 512
    normalize: true
    max_seq_length: 512
    pooling: cls
    query_prefix: "Represent this sentence for searching relevant passages:"

# FAISS vector store
rag FAISSVectorStore:
    embedder: SentenceEmbedder
    data: DocumentChunker
    index_type: IVFFlat                # IVFFlat vs HNSW vs Flat
    nlist: 1024
    nprobe: 32
    metric: cosine
    persist_dir: "vectorstore/faiss_enterprise"
    rebuild_if_exists: false

# BM25 sparse retriever for hybrid search
rag BM25Retriever:
    data: DocumentChunker
    k1: 1.5
    b: 0.75
    index_dir: "vectorstore/bm25_enterprise"

# Hybrid retriever combining dense + sparse
rag HybridRetriever:
    dense: FAISSVectorStore
    sparse: BM25Retriever
    fusion_method: reciprocal_rank_fusion
    rrf_k: 60
    top_k: 50                          # candidates before reranking

# Cross-encoder reranker
model Reranker:
    type: cross_encoder
    model: "cross-encoder/ms-marco-MiniLM-L-12-v2"
    max_seq_length: 512
    batch_size: 128
    device: cuda

# RAG pipeline with LLM generation
rag RAGPipeline:
    retriever: HybridRetriever
    reranker: Reranker
    top_k_retrieve: 50
    top_k_rerank: 5
    llm: "meta-llama/Llama-3-70B-Instruct"
    llm_config:
        max_new_tokens: 512
        temperature: 0.1
        top_p: 0.9
        repetition_penalty: 1.1
    context_window: 4096
    prompt_template: "Answer the question based only on the provided context. If the answer is not in the context, say so."
    citation_mode: inline              # add [1], [2] citations
    stream: true

# Contextual compression (filter irrelevant sentences from chunks)
rag ContextualCompressor:
    base_retriever: HybridRetriever
    compressor: LLMChainExtractor(
        llm="meta-llama/Llama-3-8B-Instruct",
        max_tokens=200
    )
    compression_threshold: 0.5

# Evaluation with RAGAS framework
evaluate RAGEvaluation:
    pipeline: RAGPipeline
    eval_dataset: "datasets/rag_eval_qa.json"  # question/answer/context triples
    metrics: [
        faithfulness,
        answer_relevancy,
        context_precision,
        context_recall,
        context_entity_recall,
        answer_correctness
    ]
    llm_judge: "gpt-4o"
    num_eval_samples: 200
    save: "outputs/rag_ragas_report.json"

monitor RAGMonitor:
    watch: [retrieval_latency_p50, retrieval_latency_p99, generation_latency,
            faithfulness, answer_relevancy, context_precision]
    log_every: query
    dashboard: "langsmith"
    project: "enterprise-rag"
    alert_if: faithfulness < 0.7
