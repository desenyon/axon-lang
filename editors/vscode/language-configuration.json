{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(model|data|train|evaluate|search|deploy|pipeline|finetune|ensemble|explain|pretrain|gan|diffusion|rl|tabular|timeseries|graph|audio|multimodal|distill|quantize|monitor|serve|test|benchmark|augment|feature|embedding|tokenizer|callback|metric|rag|agent|federated|automl|transform|loader|layers|forward|metrics|callbacks)\\s+.*:\\s*$",
    "decreaseIndentPattern": "^\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(model|data|train|evaluate)\\s+\\w+\\s*:\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*"
}
